# .gitignore ignores the entire generated /build directory, all compiled binaries, and the editor's local workspace settings.
# Never push generated build files because it bloats the repository and causes massive merge conflicts because CMake hardcodes your machines absolute file paths.

# -----------------------------------------------------------------------------
# 1. CMake & Build Directories
# -----------------------------------------------------------------------------
build/
out/
bin/
lib/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
compile_commands.json
*.cmake
!CMakeLists.txt

# -----------------------------------------------------------------------------
# 2. Compiled Binaries & Intermediate Files
# -----------------------------------------------------------------------------
*.exe
*.dll
*.so
*.dylib
*.a
*.lib
*.obj
*.o
*.pdb
*.exp
*.idb
*.ilk
*.suo
*.user

# -----------------------------------------------------------------------------
# 3. IDE & Editor Workspace Files
# -----------------------------------------------------------------------------
# Visual Studio / MSVC
.vs/
*.sln
*.vcxproj
*.vcxproj.user
*.vcxproj.filters

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# CLion / JetBrains
.idea/

# -----------------------------------------------------------------------------
# 4. Operating System Noise
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini